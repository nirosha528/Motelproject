@using Microsoft.AspNetCore.Http

@{
    var role = Context.Session.GetString("Role");
}

<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <title>@ViewData["Title"] - MotelBooking</title>

    <link rel="stylesheet" href="~/lib/bootstrap/dist/css/bootstrap.min.css" />
    <link rel="stylesheet" href="~/css/site.css" asp-append-version="true" />

    <style>
        .custom-navbar {
            background-color: #2c3e50;
            padding: 15px 0;
        }

        .navbar-brand {
            color: white !important;
            font-size: 40px;
            font-weight: 700;
        }

        .nav-btn {
            background-color: #2c3e50;
            color: white !important;
            font-weight: bold;
            border-radius: 6px;
            padding: 8px 18px;
            border: none;
            text-decoration: none;
            transition: 0.3s;
        }

            .nav-btn:hover {
                background-color: #1f2a38 !important;
                text-decoration: none;
            }

        .footer-custom {
            background-color: #2c3e50;
            color: white;
            padding: 20px 0;
            font-size: 14px;
        }

        .footer-btn {
            color: white !important;
            font-weight: bold;
            padding: 6px 15px;
            border-radius: 5px;
            text-decoration: none;
        }

            .footer-btn:hover {
                text-decoration: underline;
            }
    </style>
</head>

<body>

    <header>
        <nav class="navbar navbar-expand-lg custom-navbar">
            <div class="container d-flex align-items-center justify-content-between">

                <!-- Brand -->
                <a href="/" class="navbar-brand">Motel</a>

                <!-- NAVBAR LINKS -->
                <div class="d-flex">

                    <a asp-controller="Home" asp-action="Index" class="nav-btn mx-2">Home</a>

                    <a asp-controller="Home" asp-action="Aboutus" class="nav-btn mx-2">About Us</a>

                    <a asp-controller="Room" asp-action="Index" class="nav-btn mx-2">Accommodation</a>

                    <a asp-controller="Home" asp-action="Contactus" class="nav-btn mx-2">Contact Us</a>

                    <a asp-controller="BookingRequest" asp-action="Create" class="nav-btn mx-2">Book Now</a>


                </div>

                <!-- RIGHT SIDE -->
                <div class="d-flex">

                    @if (string.IsNullOrEmpty(role))
                    {
                        <a asp-controller="Customer" asp-action="Register" class="nav-btn mx-2">Register</a>
                        <a asp-controller="Account" asp-action="Login" class="nav-btn mx-2">Login</a>
                    }
                    else
                    {
                        <a asp-controller="Account" asp-action="Logout" class="nav-btn mx-2">Logout</a>
                    }

                </div>

            </div>
        </nav>
    </header>

    <!-- BODY -->
    <div class="container mt-3">
        <main role="main" class="pb-3">
            @RenderBody()
        </main>
    </div>

    <!-- FOOTER -->
    <footer class="footer-custom mt-5">
        <div class="container d-flex justify-content-between align-items-center text-white">

            <div>&copy; 2026 Motel Booking</div>

            <div>
                <a asp-controller="Home" asp-action="Index" class="footer-btn mx-2">Home</a>
                <a asp-controller="Home" asp-action="Aboutus" class="footer-btn mx-2">About Us</a>
                <a asp-controller="Home" asp-action="Contactus" class="footer-btn mx-2">Contact Us</a>
                <a asp-controller="BookingRequest" asp-action="Create" class="footer-btn mx-2">Book Now</a>
                <a asp-controller="Room" asp-action="Index" class="footer-btn mx-2">Accommodation</a>
            </div>

            <div>
                <a href="https://www.facebook.com" target="_blank" class="footer-btn mx-1">Facebook</a>
                <a href="https://www.twitter.com" target="_blank" class="footer-btn mx-1">Twitter</a>
                <a href="https://www.instagram.com" target="_blank" class="footer-btn mx-1">Instagram</a>
            </div>

        </div>
    </footer>

    <script src="~/lib/jquery/dist/jquery.min.js"></script>
    <script src="~/lib/bootstrap/dist/js/bootstrap.bundle.min.js"></script>
    <script src="~/js/site.js" asp-append-version="true"></script>

    @RenderSection("Scripts", required: false)

</body>
</html>