@{
    ViewData["Title"] = "Home";
}

<!-- Page Header / Title -->
<div class="text-center page-header">
    <h1 class="main-title">Motel Booking</h1>
    <p class="welcome-text">Welcome to our online motel booking system!</p>
</div>

<!-- Two-Column Image & Description Section -->
<div class="container mt-5">
    <div class="row align-items-center">
        <!-- Left Column: Image -->
        <div class="col-md-7">
            <img src="~/images/Motel.jpg" alt="Motel" class="img-fluid rounded shadow" />
        </div>

        <!-- Right Column: Description -->
        <div class="col-md-5 d-flex align-items-center">
            <div class="description-text">
                <h2>Welcome to Motel Booking</h2>
                <p>
                    Our motel offers comfortable rooms and excellent services to make your stay memorable.
                </p>
                <p>
                    Easily check room availability, book online, and enjoy a hassle-free experience.
                </p>
            </div>
        </div>
    </div>
</div>


<div class="section-spacer"></div>

<!-- Full-Width Image Cards Section -->
<div class="container-fluid bg-light py-5">
    <div class="row g-4 justify-content-between">
        <div class="col-12 col-sm-6 col-md-3">
            <div class="image-card">
                <div class="image-wrapper">
                    <img src="~/images/room2.jpg" alt="Room 1" class="img-fluid" />
                </div>
            </div>
        </div>

        <div class="col-12 col-sm-6 col-md-3">
            <div class="image-card">
                <div class="image-wrapper">
                    <img src="~/images/delux.jpg" alt="Room 2" class="img-fluid" />
                </div>
            </div>
        </div>

        <div class="col-12 col-sm-6 col-md-3">
            <div class="image-card">
                <div class="image-wrapper">
                    <img src="~/images/standed.jpg" alt="Room 3" class="img-fluid" />
                </div>
            </div>
        </div>

        <div class="col-12 col-sm-6 col-md-3">
            <div class="image-card">
                <div class="image-wrapper">
                    <img src="~/images/family.jpg" alt="Room 4" class="img-fluid" />
                </div>
            </div>
        </div>
    </div>
</div>


<!-- Book Now Button -->

<div class="container-fluid py-5" style="background-color: white;">
    <div class="container text-center">
        <h2 class="mb-4">Ready to Stay With Us?</h2>
        <a href="/BookingRequest/Create" class="btn btn-primary btn-lg">Book Now</a>
    </div>
</div>

<!--Custom CSS -->
<style>
    .btn-primary {
        background-color: #2c3e50; /* navbar/footer */
        color: white;
        font-weight: bold;
        padding: 12px 30px;
        border-radius: 8px;
        font-size: 18px;
        border: none;
        transition: background-color 0.3s;
    }

        .btn-primary:hover {
            background-color: #1f2a38; /* Darker shade on hover */
            color: white;
            text-decoration: none;
        }

    /* Section heading styling */
    .container h2 {
        color: #2c3e50;
        font-weight: bold;
    }
</style>
