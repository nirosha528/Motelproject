@{
    ViewData["Title"] = "About Us";
    Layout = "~/Views/Shared/_Layout.cshtml";
}

<div class="container mt-5">
    <h2 class="text-center mb-4">About Us</h2> <br /><br />
</div>


<!-- About Section -->
<div class="row mb-5">
    <div class="col-md-6">
        <img src="/images/about.jpg" alt="Motel" class="img-fluid rounded shadow-sm" />
    </div>
    <div class="col-md-6">
        <h4>Motel Reservation</h4>
        <p style="text-align: justify;">
            Our Smart Motel Reservation System is a modern web-based platform designed to make booking motel rooms fast and convenient. Guests can book rooms for hourly or overnight stays.
        </p>
    </div>
</div>


<!-- Second Section: Our Mission / Vision -->
<section class="py-5" style="background-color: #f2f2f2;">

    <div class="container">
        <div class="row align-items-center">
            <!-- Left Side: Text -->
            <div class="col-md-6">
                <h3>Our Mission</h3>
                <p>
                    To provide smart, flexible, and customer-friendly motel booking services
                    that leverage analytics to improve guest experiences and optimize management decisions.
                </p>
            </div>
            <!-- Right Side: Image -->
            <div class="col-md-6">
                <img src="~/images/about1.jpg" class="img-fluid rounded" alt="Our Mission">
            </div>
        </div>
    </div>
</section>
<!-- About Us - Our Location Section  -->
<section class="container my-5">
    <div class="row align-items-center">
        <!-- Left Side: Map -->
        <div class="col-md-6">
            <div class="map-responsive" style="overflow:hidden; padding-bottom:56.25%; position:relative; height:0;">
                <iframe src="https://www.google.com/maps/embed?pb=!1m18!1m12!1m3!1d3960.743504860376!2d79.8612430847769!3d6.927078995006726!2m3!1f0!2f0!3f0!3m2!1i1024!2i768!4f13.1!3m3!1m2!1s0x3ae2590d8c54f5f3%3A0x7d9c0a3f0d3c6e!2sColombo%2C%20Sri%20Lanka!5e0!3m2!1sen!2slk!4v1686183036363!5m2!1sen!2slk"
                        width="100%"
                        height="300"
                        style="border:0; position:absolute; top:0; left:0;"
                        allowfullscreen=""
                        loading="lazy"
                        referrerpolicy="no-referrer-when-downgrade">
                </iframe>
            </div>
        </div>

        <!-- Right Side: Description -->
        <div class="col-md-6">
            <h3>Our Location</h3>
            <p style="text-align: justify;">
                Our motel is located in the Waikkala, Sri Lanka. Guests can enjoy convenient access to major landmarks, shopping districts, and public transport.
                The location provides both comfort and connectivity, making it ideal for travelers seeking a memorable stay in the city.
            </p>
        </div>
    </div>
</section>