@model MotelBooking.Models.BookingRequest

<h2>Delete Booking Request</h2>

<h4>Are you sure you want to delete this request?</h4>

<hr />

<div class="mb-3">
    <p><b>Customer Name:</b> @Model.CustomerName</p>
    <p><b>Room No:</b> @Model.RoomNo</p>
    <p><b>Room Type:</b> @Model.RoomType</p>
    <p><b>Check In:</b> @Model.CheckIn</p>
    <p><b>Check Out:</b> @Model.CheckOut</p>
    <p><b>Status:</b> @Model.Status</p>
</div>

<form asp-action="Delete" method="post">
    <input type="hidden" asp-for="RequestID" />

    <button type="submit" class="btn btn-danger">
        Delete
    </button>

    <a asp-action="AdminRequest" class="btn btn-secondary">
        Cancel
    </a>
</form>