@model MotelBooking.Models.CustomerAnalyticsViewModel

<div class="container mt-4">

    <!-- HEADER -->
    <div class="d-flex justify-content-between align-items-center mb-4">
        <h2 class="fw-bold">📊 Customer Analytics Dashboard</h2>
    </div>

    <br />
<br />


    <!-- SUMMARY CARDS -->
    <div class="row g-3">

        <div class="col-md-4">
            <div class="card shadow-sm border-0 p-3 text-center">
                <h6 class="text-muted">⭐ Popular Room</h6>
                <h3 class="text-primary fw-bold">@Model.PopularRoom</h3>
            </div>
        </div>

        <div class="col-md-4">
            <div class="card shadow-sm border-0 p-3 text-center">
                <h6 class="text-muted">⏰ Peak Booking Hour</h6>
                <h3 class="text-success fw-bold">@Model.PeakHour:00</h3>
            </div>
        </div>

        <div class="col-md-4">
            <div class="card shadow-sm border-0 p-3 text-center">
                <h6 class="text-muted">📅 Total Months Tracked</h6>
                <h3 class="text-warning fw-bold">@Model.MonthlyBookings.Count</h3>
            </div>
        </div>

    </div>

    <br /><br /><br />

    <!-- MONTHLY BOOKINGS -->
    <div class="card shadow-sm border-0 mt-4">
        <div class="card-header bg-primary text-white">
            📅 Monthly Bookings
        </div>

        <div class="card-body p-0">
            <table class="table table-hover mb-0">
                <thead class="table-light">
                    <tr>
                        <th>Month</th>
                        <th>Total Bookings</th>
                    </tr>
                </thead>

                <tbody>
                    @foreach (var item in Model.MonthlyBookings)
                    {
                        <tr>
                            <td>@item.Month</td>
                            <td><span class="badge bg-primary">@item.Total</span></td>
                        </tr>
                    }
                </tbody>
            </table>
        </div>
    </div>

    <br />
    <br>
    <br /><b> <br /></b>
    <!-- CUSTOMER GROWTH -->
    <div class="card shadow-sm border-0 mt-4">
        <div class="card-header bg-success text-white">
            📈 Customer Growth
        </div>

        <div class="card-body p-0">
            <table class="table table-hover mb-0">
                <thead class="table-light">
                    <tr>
                        <th>Month</th>
                        <th>Customers</th>
                    </tr>
                </thead>

                <tbody>
                    @foreach (var item in Model.CustomerGrowth)
                    {
                        <tr>
                            <td>@item.Month</td>
                            <td><span class="badge bg-success">@item.Customers</span></td>
                        </tr>
                    }
                </tbody>
            </table>
        </div>
    </div>

</div>