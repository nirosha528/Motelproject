@{
    ViewData["Title"] = "Contact Us";
    Layout = "~/Views/Shared/_Layout.cshtml";
}

<!-- Hero Section -->
<section class="hero-section text-center mb-5">

    <h1 class="mt-3">Get in Touch</h1>

    <img src="~/images/er.jpg" alt="Contact Us" class="img-fluid w-100" style="max-height: 400px; object-fit: cover;">
</section>

<!-- Contact Cards Section -->
<section class="container mb-5">
    <div class="row text-center">
        <!-- Address Card -->
        <div class="col-md-4 mb-3">
            <div class="card h-100 shadow-sm border-primary border-2">
                <div class="card-body">
                    <h5 class="card-title">Address</h5>
                    <p class="card-text" style="text-align: justify center;">
                        Waikkala, SriLanka
                    </p>
                </div>
            </div>
        </div>

        <!-- Email Card -->
        <div class="col-md-4 mb-3">
            <div class="card h-100 shadow-sm border-primary border-2">
                <div class="card-body">
                    <h5 class="card-title">Email</h5>
                    <p class="card-text" style="text-align: justify center;">
                        teniroaccommodation.com
                    </p>
                </div>
            </div>
        </div>

        <!-- Office Hours Card -->
        <div class="col-md-4 mb-3">
            <div class="card h-100 shadow-sm border-primary border-2">
                <div class="card-body">
                    <h5 class="card-title">Office Hours</h5>
                    <p class="card-text" style="text-align: justify center;">
                        Mon – Fri: 9:00 AM – 6:00 PM
                        <br />
                        Sat – Sun: 10:00 AM – 4:00 PM
                    </p>
                </div>
            </div>
        </div>
    </div>
</section>
<!-- Inquiry Form Section (Two Columns) -->
<section class="container my-5">
    <div class="row align-items-center">
        <!-- Left Column: Image -->
        <div class="col-md-6 mb-4 mb-md-0">
            <img src="~/images/standed1.jpg" alt="Contact Image" class="img-fluid rounded" style="width: 100%; height: auto;">
        </div>

        <!-- Right Column: Inquiry Form -->
        <div class="col-md-6">
            <h3 class="mb-4">Send Us Your Inquiry</h3>
            <form asp-action="SubmitInquiry" method="post">
                <div class="mb-3">
                    <label for="Name" class="form-label">Full Name</label>
                    <input type="text" class="form-control" id="Name" name="Name" placeholder="Your full name" required>
                </div>
                <div class="mb-3">
                    <label for="Email" class="form-label">Email Address</label>
                    <input type="email" class="form-control" id="Email" name="Email" placeholder="Your email" required>
                </div>
                <div class="mb-3">
                    <label for="Subject" class="form-label">Subject</label>
                    <input type="text" class="form-control" id="Subject" name="Subject" placeholder="Subject of your inquiry" required>
                </div>
                <div class="mb-3">
                    <label for="Message" class="form-label">Message</label>
                    <textarea class="form-control" id="Message" name="Message" rows="5" placeholder="Type your message here..." required></textarea>
                </div>
                <button type="submit" class="btn btn-primary">Send Message</button>
            </form>
        </div>
    </div>
</section>